# Test Environment Configuration
# Copy this file to .env.test and fill in the values

# Supabase Test Project/Branch Configuration
VITE_SUPABASE_URL=https://your-test-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-test-anon-key

# Service role key for test setup/teardown (DO NOT COMMIT)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Test Configuration
TEST_TIMEOUT=30000
TEST_RETRY_ATTEMPTS=3

# BrowserStack Configuration (for E2E mobile tests)
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# Test User Credentials (seeded in test database)
TEST_EMPLOYEE_EMAIL=test-employee@atts.test
TEST_EMPLOYEE_PASSWORD=TestPassword123!
TEST_FOREMAN_EMAIL=test-foreman@atts.test
TEST_FOREMAN_PASSWORD=TestPassword123!
TEST_MECHANIC_EMAIL=test-mechanic@atts.test
TEST_MECHANIC_PASSWORD=TestPassword123!
TEST_GF_EMAIL=test-gf@atts.test
TEST_GF_PASSWORD=TestPassword123!
TEST_ADMIN_EMAIL=test-admin@atts.test
TEST_ADMIN_PASSWORD=TestPassword123!
