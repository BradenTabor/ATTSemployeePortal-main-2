# ATTS Employee Portal - Environment Variables
# Copy this file to .env and fill in your values
# NOTE: All VITE_ prefixed variables are exposed to the client

# ============================================================================
# REQUIRED - Supabase Configuration
# ============================================================================

# Your Supabase project URL (found in Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key (found in Settings > API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# OPTIONAL - Push Notifications (Web Push / VAPID)
# ============================================================================

# VAPID public key for web push notifications
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# ============================================================================
# OPTIONAL - Google Maps Integration
# ============================================================================

# Google Maps API key for location picker feature
# Get from: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=

# ============================================================================
# OPTIONAL - Make.com Webhook Integration
# ============================================================================

# Make.com webhook URL for DVIR form submissions (optional)
VITE_MAKE_DVIR_WEBHOOK_URL=

# Make.com webhook URL for RTO (Request Time Off) submissions (optional)
VITE_MAKE_RTO_WEBHOOK_URL=

# ============================================================================
# OPTIONAL - Telemetry Configuration
# ============================================================================

# Set to 'false' to disable client-side telemetry (default: enabled)
VITE_TELEMETRY_ENABLED=true

# ============================================================================
# SERVER-SIDE ONLY (for Edge Functions / Safety Agent)
# DO NOT prefix with VITE_ - these are not exposed to client
# ============================================================================

# Supabase service role key for server-to-server operations
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API key for safety agent / AI features
# OPENAI_API_KEY=sk-your-openai-key
