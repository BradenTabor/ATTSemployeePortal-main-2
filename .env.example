# ATTS Employee Portal - Environment Variables
# Copy this file to .env and fill in your values
# NOTE: All VITE_ prefixed variables are exposed to the client

# ============================================================================
# REQUIRED - Supabase Configuration
# ============================================================================

# Your Supabase project URL (found in Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key (found in Settings > API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# OPTIONAL - Push Notifications (Web Push / VAPID)
# ============================================================================

# VAPID public key for web push notifications
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# ============================================================================
# OPTIONAL - Google Maps Integration
# ============================================================================

# Google Maps API key (location picker, EAP GPS reverse-geocoding)
# Enable Geocoding API in Google Cloud Console
# Get from: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=

# ============================================================================
# OPTIONAL - Make.com Webhook Integration
# ============================================================================

# Make.com webhook URL for DVIR form submissions (optional)
VITE_MAKE_DVIR_WEBHOOK_URL=

# Make.com webhook URL for RTO (Request Time Off) submissions (optional)
VITE_MAKE_RTO_WEBHOOK_URL=

# Make.com webhook URL for daily safety/compliance email (optional; used by Edge Functions)
# VITE_MAKE_DEN_WEBHOOK_URL=

# App base URL for links in emails (optional; used by Edge Functions; defaults to Vercel URL)
# VITE_APP_BASE_URL=https://your-app.vercel.app

# ============================================================================
# OPTIONAL - Video CDN (Vercel bandwidth optimization)
# ============================================================================
# Base URL for video assets. When set, dashboard/home/safety-briefing videos are
# loaded from this origin instead of Vercel. Upload public/videos/*.mp4 to
# Cloudflare R2, S3+CloudFront, or similar and set e.g. https://your-bucket.r2.dev
# VITE_VIDEO_CDN_BASE_URL=

# ============================================================================
# OPTIONAL - Telemetry Configuration
# ============================================================================

# Set to 'false' to disable client-side telemetry (default: enabled)
VITE_TELEMETRY_ENABLED=true

# ============================================================================
# SERVER-SIDE ONLY (for Edge Functions / Safety Agent)
# DO NOT prefix with VITE_ - these are not exposed to client
# ============================================================================

# Supabase service role key for server-to-server operations
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API key for safety agent / AI features
# OPENAI_API_KEY=sk-your-openai-key

# Database URL for deploy-cron-auth.sh (Postgres URI from Dashboard → Database → Connection string)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Gmail for compliance / weekly safety emails (set in Supabase Edge Function secrets)
# GMAIL_USER=your-gmail@gmail.com
# GMAIL_APP_PASSWORD=app-password-from-google-account

# ClickSend SMS for safety briefing escalation (set in Supabase Edge Function secrets)
# CLICKSEND_USERNAME=your-clicksend-username
# CLICKSEND_PASSWORD=your-clicksend-api-key

# Weekly Safety Audit Report (Friday 5 PM CST) — set in Supabase Edge Function secrets
# ATTS_LOGO_URL=https://your-cdn/logo.png
# WEEKLY_SAFETY_REPORT_FALLBACK_RECIPIENTS=admin@example.com,safety@example.com
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  (full JSON string)
# GOOGLE_SHEETS_SAFETY_AUDIT_ID=spreadsheet-id-from-url
