{
  "name": "atts-employee-portal",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "overrides": {
    "tmp": "0.2.5"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run bundle:check",
    "release:patch": "npm version patch && echo 'Version bumped! Run npm run build to create new release'",
    "release:minor": "npm version minor && echo 'Version bumped! Remember to update WHATS_NEW_FEATURES in src/lib/appVersion.ts'",
    "release:major": "npm version major && echo 'Version bumped! Remember to update WHATS_NEW_FEATURES in src/lib/appVersion.ts'",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:ci": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:unit": "vitest run --config tests/vitest.config.ts",
    "test:unit:watch": "vitest --config tests/vitest.config.ts",
    "test:unit:coverage": "vitest run --config tests/vitest.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:setup": "npx tsx tests/setup/seedTestUsers.ts",
    "test:setup:cleanup": "npx tsx tests/setup/seedTestUsers.ts --cleanup",
    "test:fixtures": "npx tsx tests/setup/generateFixtures.ts",
    "test:compliance:dry-run": "npx tsx scripts/test-compliance-forms-dry-run.ts",
    "import-cert-questions": "npx tsx scripts/import-cert-questions.ts",
    "bundle:check": "node scripts/checkBundleSize.mjs",
    "lighthouse": "npm run build && lhci autorun",
    "accessibility": "start-server-and-test preview:ci http://127.0.0.1:4173 pa11y-ci",
    "verify:ios": "node scripts/verify-ios-pwa.mjs",
    "test:pwa": "npm run verify:ios && npm run build && npm run preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-google-maps/api": "^2.20.8",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@types/papaparse": "^5.5.2",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.344.0",
    "nodemailer": "^7.0.12",
    "openai": "^6.15.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.68.0",
    "react-image-crop": "^11.0.10",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.9.4",
    "react-use-measure": "^2.1.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.13",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.9.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.9.0",
    "jsdom": "^27.2.0",
    "pa11y-ci": "^4.0.1",
    "postcss": "^8.4.31",
    "shadcn": "^3.7.0",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.14"
  }
}
