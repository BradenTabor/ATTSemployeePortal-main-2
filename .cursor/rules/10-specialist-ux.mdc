        <article className="card group relative overflow-hidden p-6 rounded-xl
          border border-[--border] bg-[--surface]">
          {/* Decorative corner gradient — generated image or CSS */}
          <div className="absolute bottom-0 right-0 w-32 h-32 pointer-events-none opacity-10
            bg-gradient-to-tl from-[--primary] to-transparent rounded-tl-full
            transition-opacity group-hover:opacity-20" aria-hidden="true" />
          <FeatureIcon icon={Icon} label={feature.title} />
          <h3 className="mt-4 text-lg font-semibold tracking-tight">{feature.title}</h3>
          <p className="mt-2 text-sm text-[--muted-foreground] leading-relaxed">{feature.description}</p>
        </article>
      </ScrollReveal>
    )
  })}
</div>
```

