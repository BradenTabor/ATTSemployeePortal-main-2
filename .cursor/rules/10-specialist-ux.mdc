### Geometric Shape Layer (Editorial / Brutalist)

```tsx
// SVG geometric shapes as background decoration — scaled, rotated, layered
export function GeometricLayer({ direction = 'editorial' }: { direction?: string }) {
  const shapes = direction === 'brutalist' ? [
    // Hard rectangles and lines
    { type: 'rect', x: -20, y: 40, w: 120, h: 8, rotate: 15, opacity: 0.06 },
    { type: 'rect', x: 80, y: 20, w: 8, h: 200, rotate: -5, opacity: 0.04 },
  ] : [
    // Soft circles and ellipses  
    { type: 'circle', cx: 10, cy: 20, r: 8, opacity: 0.08 },
    { type: 'circle', cx: 90, cy: 70, r: 12, opacity: 0.05 },
    { type: 'circle', cx: 50, cy: 90, r: 6, opacity: 0.06 },
  ]

  return (
    <svg className="absolute inset-0 w-full h-full pointer-events-none"
      aria-hidden="true" style={{ zIndex: -1 }}>
      {shapes.map((s, i) => s.type === 'circle'
        ? <circle key={i} cx={`${s.cx}%`} cy={`${s.cy}%`} r={`${s.r}%`}
            fill="var(--primary)" opacity={s.opacity} />
        : <rect key={i} x={`${s.x}%`} y={`${s.y}%`} width={`${s.w}%`} height={`${s.h}%`}
            fill="var(--primary)" opacity={s.opacity}
            transform={`rotate(${s.rotate || 0})`} />
      )}
    </svg>
  )
}
```

